#!/usr/bin/env sh
set -e

# Railway build command shim: ./gradlew clean build
# Actual build uses Maven.
# Root Directory: backend
# Build Command: ./services/media-service/gradlew clean build
# Target: backend/services/media-service (self)

# 현재 스크립트 위치 확인 (backend/services/media-service)
SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
SERVICE_DIR="$SCRIPT_DIR"
POM_FILE="$SERVICE_DIR/pom.xml"

# 경로 확인
if [ ! -f "$POM_FILE" ]; then
  echo "Error: POM file not found at $POM_FILE" >&2
  echo "Current directory: $(pwd)" >&2
  echo "Script directory: $SCRIPT_DIR" >&2
  exit 1
fi

# Maven wrapper 또는 Maven 찾기
if [ -x "$SERVICE_DIR/mvnw" ]; then
  MVN_CMD="$SERVICE_DIR/mvnw"
  echo "Using Maven wrapper: $MVN_CMD"
elif command -v mvn >/dev/null 2>&1; then
  MVN_CMD="mvn"
  echo "Using system Maven: $MVN_CMD"
else
  echo "Error: mvn not found in PATH" >&2
  echo "Checked locations:" >&2
  echo "  - $SERVICE_DIR/mvnw" >&2
  exit 127
fi

# Railpack 호환성: /app/target 디렉터리 생성 (Railway 빌더가 기대하는 위치)
# Root Directory가 backend이므로, /app은 backend에 해당
BASE_DIR="$(cd "$SERVICE_DIR/../.." && pwd)"
TARGET_DIR="$BASE_DIR/target"
if [ ! -d "$TARGET_DIR" ]; then
  echo "Creating target directory for Railpack compatibility: $TARGET_DIR"
  mkdir -p "$TARGET_DIR"
fi

# 빌드 실행
echo "Building media-service..."
echo "  POM: $POM_FILE"
echo "  Maven: $MVN_CMD"
echo "  Current directory: $(pwd)"
cd "$SERVICE_DIR" || exit 1
exec "$MVN_CMD" -f "$POM_FILE" -DskipTests clean package
